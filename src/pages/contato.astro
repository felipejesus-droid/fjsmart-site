---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contato"
  description="Fale com a FJ Smart — Inteligência Pessoal. WhatsApp, e-mail ou formulário de contato. Resposta em até 24h."
  ogImage="/og-contato.png"
>

  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="ct-hero section" aria-label="Contato">
    <div class="ct-bg" aria-hidden="true">Δ</div>
    <div class="container">
      <div class="ct-hero-inner">
        <div class="eyebrow">Vamos conversar</div>
        <h1>Fale com a <span class="ct-accent">FJ Smart</span></h1>
        <p class="ct-lead">
          Empresa ou profissional individual, a primeira conversa é sempre de alinhamento —
          sem compromisso. Escolha o canal que preferir.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CANAIS + FORM ═══════════════════════════════════════ -->
  <section class="section section--sm contact-section" aria-label="Canais de contato">
    <div class="container">
      <div class="contact-grid">

        <!-- CANAIS -->
        <div class="channels">
          <a href="https://wa.me/5554996419886?text=Olá%20Felipe!%20Vim%20pelo%20site%20da%20FJ%20Smart%20e%20gostaria%20de%20conversar." target="_blank" rel="noopener" class="channel-card channel-card--wa">
            <div class="channel-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.532 5.862L.057 23.743a.5.5 0 00.625.626l5.88-1.474A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.895 0-3.668-.52-5.183-1.427l-.371-.22-3.847.963.983-3.847-.228-.374A10 10 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            </div>
            <div class="channel-text">
              <div class="channel-label">WhatsApp · resposta mais rápida</div>
              <div class="channel-value">(54) 99641-9886</div>
            </div>
            <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>

          <a href="mailto:felipe@fjsmart.com.br?subject=Contato%20via%20site%20FJ%20Smart" class="channel-card">
            <div class="channel-icon" style="color:var(--electric-cyan);border-color:var(--border-cyan);background:rgba(0,212,255,0.04)">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            </div>
            <div class="channel-text">
              <div class="channel-label">E-mail</div>
              <div class="channel-value">felipe@fjsmart.com.br</div>
            </div>
            <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>

          <a href="https://www.linkedin.com/in/felipe-jesus-888a2140a/" target="_blank" rel="noopener" class="channel-card">
            <div class="channel-icon" style="color:var(--electric-cyan);border-color:var(--border-cyan);background:rgba(0,212,255,0.04)">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <div class="channel-text">
              <div class="channel-label">LinkedIn</div>
              <div class="channel-value">felipe-jesus</div>
            </div>
            <svg class="channel-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>

          <div class="channel-note">
            <span class="eyebrow">Tempo de resposta</span>
            <p>Até 24h em dias úteis. Para urgências, o WhatsApp é o canal mais rápido.</p>
          </div>
        </div>

        <!-- FORM -->
        <div class="contact-form-wrap">
          <div class="eyebrow" style="display:block;margin-bottom:0.75rem;">Ou preencha o formulário</div>
          <h2 style="margin-bottom:1.5rem;">Contato rápido</h2>
          <form
            id="contact-form"
            class="contact-form"
          >
            <div class="form-row">
              <label for="nome">Nome</label>
              <input type="text" id="nome" name="nome" required placeholder="Seu nome" />
            </div>
            <div class="form-row">
              <label for="email">E-mail</label>
              <input type="email" id="email" name="email" required placeholder="seu@email.com" />
            </div>
            <div class="form-row">
              <label for="perfil">Você é...</label>
              <select id="perfil" name="perfil">
                <option value="empresa">Empresa / Gestor (B2B)</option>
                <option value="profissional">Profissional individual (B2C)</option>
                <option value="outro">Outro</option>
              </select>
            </div>
            <div class="form-row">
              <label for="mensagem">Mensagem</label>
              <textarea id="mensagem" name="mensagem" rows="4" required placeholder="Conte um pouco sobre o seu contexto e o que você busca..."></textarea>
            </div>
            <button type="submit" id="contact-submit" class="btn btn--primary" style="width:100%;justify-content:center;">
              Enviar mensagem
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </form>
          <div id="contact-status" class="form-note" style="display:none;"></div>
        </div>

        <script>
          const SUPABASE_URL = "https://vlhwbygaahmijcmpjsdh.supabase.co";
          const SUPABASE_ANON_KEY = "sb_publishable_LFofY9jJEi1kcMqAhyXXBQ_5AbSf_En";

          const form = document.getElementById("contact-form");
          const status = document.getElementById("contact-status");
          const submitBtn = document.getElementById("contact-submit");

          form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            submitBtn.disabled = true;
            const originalText = submitBtn.innerHTML;
            submitBtn.textContent = "Enviando...";

            const data = {
              nome: form.nome.value,
              email: form.email.value,
              perfil: form.perfil.value,
              mensagem: form.mensagem.value,
            };

            try {
              const res = await fetch(`${SUPABASE_URL}/rest/v1/leads`, {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                  apikey: SUPABASE_ANON_KEY,
                  Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
                  Prefer: "return=minimal",
                },
                body: JSON.stringify(data),
              });

              if (res.ok) {
                status.textContent = "✅ Mensagem enviada! Retornaremos em até 24h.";
                status.style.color = "var(--electric-cyan)";
                status.style.display = "block";
                form.reset();
              } else {
                throw new Error("Erro ao enviar");
              }
            } catch (err) {
              status.textContent = "⚠️ Não foi possível enviar agora. Tente novamente ou use o WhatsApp/e-mail acima.";
              status.style.color = "var(--strategic-gold)";
              status.style.display = "block";
            } finally {
              submitBtn.disabled = false;
              submitBtn.innerHTML = originalText;
            }
          });
        </script>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ────────────────────────────────────────────── */
  .ct-hero { padding-top: 5rem; overflow: hidden; position: relative; }
  .ct-bg {
    position: absolute;
    right: -3%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(220px, 32vw, 460px);
    font-weight: 800;
    color: rgba(0,212,255,0.035);
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }
  .ct-hero-inner { max-width: 620px; position: relative; z-index: 1; }
  .ct-hero-inner .eyebrow { display: block; margin-bottom: 1rem; }
  .ct-hero-inner h1 { margin-bottom: 1.25rem; }
  .ct-accent { color: var(--electric-cyan); }
  .ct-lead { font-size: 15px; }

  /* ─── GRID ────────────────────────────────────────────── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 3rem;
  }

  /* ─── CHANNELS ────────────────────────────────────────── */
  .channels { display: flex; flex-direction: column; gap: 0.85rem; }
  .channel-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .channel-card:hover { border-color: var(--border-cyan); transform: translateY(-1px); }
  .channel-card--wa:hover { border-color: rgba(37,211,102,0.4); }
  .channel-icon {
    width: 42px; height: 42px;
    border: 0.5px solid var(--border-cyan);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    color: #25D366;
    background: rgba(37,211,102,0.06);
  }
  .channel-card:not(.channel-card--wa) .channel-icon {
    color: var(--electric-cyan);
  }
  .channel-text { flex: 1; }
  .channel-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 3px;
  }
  .channel-value { font-size: 14px; color: var(--off-white); font-weight: 500; }
  .channel-arrow { color: var(--text-dim); flex-shrink: 0; transition: color 0.2s; }
  .channel-card:hover .channel-arrow { color: var(--electric-cyan); }

  .channel-note {
    margin-top: 0.5rem;
    padding: 1.1rem 1.25rem;
    border: 0.5px solid var(--border);
    border-radius: 10px;
    background: rgba(255,255,255,0.015);
  }
  .channel-note .eyebrow { display: block; margin-bottom: 0.5rem; }
  .channel-note p { font-size: 12.5px; line-height: 1.6; }

  /* ─── FORM ────────────────────────────────────────────── */
  .contact-form-wrap {
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: 12px;
    padding: 2rem;
  }
  .contact-form { display: flex; flex-direction: column; gap: 1.1rem; }
  .form-row { display: flex; flex-direction: column; gap: 0.5rem; }
  .form-row label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .form-row input,
  .form-row select,
  .form-row textarea {
    background: rgba(255,255,255,0.03);
    border: 0.5px solid var(--border);
    border-radius: 6px;
    padding: 0.7rem 0.9rem;
    color: var(--off-white);
    font-family: var(--font-body);
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
  }
  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus { border-color: var(--electric-cyan); }
  .form-row textarea { resize: vertical; }
  .form-note {
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 10px;
    color: rgba(220,175,60,0.6);
    line-height: 1.7;
    letter-spacing: 0.02em;
  }
  .form-note code {
    background: rgba(0,212,255,0.08);
    color: var(--electric-cyan);
    padding: 1px 5px;
    border-radius: 3px;
    font-family: var(--font-mono);
  }

  /* ─── RESPONSIVE ──────────────────────────────────────── */
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
