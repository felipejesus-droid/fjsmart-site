---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Preciso contratar as 5 fases de uma vez?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Não. A entrada mais comum é pelo Diagnóstico (Fase D), que já entrega valor isolado. A partir dele, a continuidade para Estratégia, Lançamento, Transferência e Autonomia é recomendada — mas decidida fase a fase, com base no que o Diagnóstico revelar."
      }
    },
    {
      "@type": "Question",
      "name": "O que diferencia o DELTA de uma consultoria de tecnologia comum?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Duas coisas: (1) o ponto de partida é sempre um diagnóstico mensurável, nunca uma venda de ferramenta; e (2) o critério de sucesso é a autonomia do cliente — o projeto é considerado bem-sucedido quando a FJ Smart se torna opcional, não indispensável."
      }
    },
    {
      "@type": "Question",
      "name": "O FJ Smart Score serve para empresas de qualquer tamanho?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sim. As 5 dimensões (Estratégia, Processos, Dados, Tecnologia, Pessoas) são aplicáveis tanto a uma operação de poucas pessoas quanto a empresas com múltiplas áreas — o que muda é a profundidade da entrevista e do roadmap gerado."
      }
    },
    {
      "@type": "Question",
      "name": "E se eu for um profissional individual, não uma empresa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "O Método DELTA também se aplica em versão B2C — veja a Imersão IA Aplicada e o Diagnóstico Individual, que seguem a mesma lógica de Diagnóstico → Estratégia → Autonomia adaptada à escala de uma carreira."
      }
    }
  ]
};
---

<BaseLayout
  title="Método DELTA™"
  description="Método DELTA™ da FJ Smart: 5 fases para maturidade em IA — Diagnóstico, Estratégia, Lançamento, Transferência, Autonomia. Conheça o FJ Smart Score."
  ogImage="/og-metodo-delta.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="md-hero section" aria-label="Método DELTA">
    <div class="md-bg" aria-hidden="true">Δ</div>
    <div class="container">
      <div class="md-hero-inner">
        <div class="eyebrow">Framework Proprietário · FJ Smart</div>
        <h1>O Método <span class="md-accent">DELTA™</span></h1>
        <p class="md-lead">
          Δ — em matemática, a letra grega que representa <strong>variação</strong>.
          É exatamente isso que o Método DELTA entrega: a distância mensurável entre
          onde sua empresa está hoje e onde ela pode estar com IA aplicada com método.
        </p>
        <p>
          Cinco fases. Um único objetivo: transformação real, documentada e sustentável —
          que termina com a sua equipe operando <strong>sem depender de nós</strong>.
        </p>
        <div class="md-ctas">
          <a href="/diagnostico" class="btn btn--primary">
            Começar pela Fase D — Diagnóstico
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#score" class="btn btn--ghost">Entender o FJ Smart Score</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ POR QUE UM MÉTODO ═══════════════════════════════════ -->
  <section class="section section--sm why-method" aria-label="Por que um método">
    <div class="container container--narrow">
      <div class="why-grid">
        <div class="why-item">
          <div class="why-icon" style="color:var(--electric-cyan)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          </div>
          <h3>Ferramenta não é estratégia</h3>
          <p>Qualquer pessoa instala um app de IA. Poucas sabem qual processo automatizar primeiro, em qual ordem, e com qual critério de sucesso.</p>
        </div>
        <div class="why-item">
          <div class="why-icon" style="color:var(--strategic-gold)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3>Sem baseline, não há prova</h3>
          <p>Sem medir o ponto de partida, é impossível provar o impacto depois. O DELTA começa e termina com um número: o Score Δ.</p>
        </div>
        <div class="why-item">
          <div class="why-icon" style="color:#A78BFA">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Autonomia é o critério de sucesso</h3>
          <p>Um projeto de IA bem-sucedido é aquele em que a sua equipe não precisa mais de um consultor para operá-lo.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ AS 5 FASES — DETALHADO ═════════════════════════════ -->
  <section class="section phases" aria-label="As 5 fases do Método DELTA">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">As 5 fases</div>
        <h2>Da letra D à letra A — um caminho, não uma lista de serviços</h2>
        <p class="section-sub">
          Cada fase entrega um resultado tangível e prepara o terreno para a próxima.
          É possível contratar o ciclo completo ou entrar por uma fase específica — mas a sequência sempre importa.
        </p>
      </div>

      <!-- FASE D -->
      <div class="phase-row" id="diagnostico">
        <div class="phase-marker">
          <span class="phase-letter delta-d">D</span>
          <div class="phase-line"></div>
        </div>
        <div class="phase-content">
          <div class="phase-tagrow">
            <span class="badge badge--cyan">Fase 01 · Onde você está</span>
          </div>
          <h3>Diagnóstico</h3>
          <p class="phase-desc">
            Tudo começa com clareza, não com ferramentas. Nesta fase, mapeamos os processos críticos
            do negócio, aplicamos o <strong>FJ Smart Score</strong> nas 5 dimensões e identificamos
            as oportunidades de IA com maior potencial de retorno — priorizadas, não apenas listadas.
          </p>
          <div class="phase-grid">
            <div class="phase-block">
              <div class="pb-label">Como</div>
              <p>Briefing de alinhamento (30 min) + entrevista estruturada (90 min) com os decisores do negócio.</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Entrega</div>
              <p>FJ Smart Score · Relatório executivo (8–12 páginas) · Top 3 oportunidades por ROI · Roadmap de 90 dias.</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Prazo típico</div>
              <p>5–7 dias úteis a partir da entrevista.</p>
            </div>
          </div>
          <a href="/diagnostico" class="btn btn--ghost phase-link">Ver detalhes do Diagnóstico →</a>
        </div>
      </div>

      <!-- FASE E -->
      <div class="phase-row">
        <div class="phase-marker">
          <span class="phase-letter delta-e">E</span>
          <div class="phase-line"></div>
        </div>
        <div class="phase-content">
          <div class="phase-tagrow">
            <span class="badge" style="color:#4ADE80;border-color:rgba(74,222,128,0.25);background:rgba(74,222,128,0.06)">Fase 02 · Para onde ir</span>
          </div>
          <h3>Estratégia</h3>
          <p class="phase-desc">
            Com o diagnóstico em mãos, a fase de Estratégia transforma oportunidades em um plano de ação
            concreto. Aqui se decide <strong>qual IA, para qual problema, com qual critério de sucesso</strong> —
            evitando o erro mais comum: adotar tecnologia antes de definir o objetivo.
          </p>
          <div class="phase-grid">
            <div class="phase-block">
              <div class="pb-label">Como</div>
              <p>Workshop de priorização com a liderança, usando os dados do Diagnóstico como ponto de partida.</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Entrega</div>
              <p>Plano de ação detalhado · Stack de ferramentas de IA recomendado · KPIs e critérios de sucesso aprovados.</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Resultado</div>
              <p>A organização sabe exatamente o que será construído, por quê, e como será medido.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- FASE L -->
      <div class="phase-row">
        <div class="phase-marker">
          <span class="phase-letter delta-l">L</span>
          <div class="phase-line"></div>
        </div>
        <div class="phase-content">
          <div class="phase-tagrow">
            <span class="badge" style="color:#FB923C;border-color:rgba(251,146,60,0.25);background:rgba(251,146,60,0.06)">Fase 03 · Construir junto</span>
          </div>
          <h3>Lançamento</h3>
          <p class="phase-desc">
            A solução sai do papel. Esta é a fase de <strong>co-construção</strong> — a equipe da FJ Smart
            constrói ao lado da equipe do cliente, não no lugar dela. Isso garante que o que for entregue
            já nasce adaptado à realidade operacional e com adoção real desde o primeiro dia.
          </p>
          <div class="phase-grid">
            <div class="phase-block">
              <div class="pb-label">Como</div>
              <p>Sprints de implementação com testes e validação contínua junto à equipe operacional.</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Entrega</div>
              <p>Solução em produção · Fluxos documentados (SOPs atualizados) · Ajustes finos com base no uso real.</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Princípio</div>
              <p>Nada é entregue "fechado" — a equipe acompanha cada decisão técnica tomada.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- FASE T -->
      <div class="phase-row">
        <div class="phase-marker">
          <span class="phase-letter delta-t">T</span>
          <div class="phase-line"></div>
        </div>
        <div class="phase-content">
          <div class="phase-tagrow">
            <span class="badge" style="color:#A78BFA;border-color:rgba(167,139,250,0.25);background:rgba(167,139,250,0.06)">Fase 04 · Educar e capacitar</span>
          </div>
          <h3>Transferência</h3>
          <p class="phase-desc">
            A fase mais negligenciada por consultorias tradicionais — e a mais importante para a FJ Smart.
            Aqui o conhecimento é <strong>transferido formalmente</strong> para a equipe: workshops práticos,
            simulações com cenários reais e um Playbook de IA escrito sob medida.
          </p>
          <div class="phase-grid">
            <div class="phase-block">
              <div class="pb-label">Como</div>
              <p>Workshops práticos com a equipe + simulação de cenários reais do dia a dia.</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Entrega</div>
              <p>Playbook de IA personalizado · Equipe certificada na operação da solução · 30 dias de suporte pós-lançamento.</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Por quê</div>
              <p>Sem transferência de conhecimento, a transformação não sobrevive à saída do consultor.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- FASE A -->
      <div class="phase-row phase-row--last">
        <div class="phase-marker">
          <span class="phase-letter delta-a">A</span>
        </div>
        <div class="phase-content">
          <div class="phase-tagrow">
            <span class="badge" style="color:#34D399;border-color:rgba(52,211,153,0.25);background:rgba(52,211,153,0.06)">Fase 05 · Voar solo</span>
          </div>
          <h3>Autonomia</h3>
          <p class="phase-desc">
            O encerramento formal do ciclo — e a prova de que ele funcionou. 30 dias após o lançamento,
            aplicamos novamente o <strong>FJ Smart Score</strong>. A diferença entre o score de entrada e
            o de saída é o <strong>Score Δ</strong>: a evidência concreta de transformação.
          </p>
          <div class="phase-grid">
            <div class="phase-block">
              <div class="pb-label">Como</div>
              <p>Check-in de 30 dias + reaplicação do FJ Smart Score nas mesmas 5 dimensões.</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Entrega</div>
              <p>Score Δ documentado · Case de transformação · Roadmap para a próxima iniciativa (se houver).</p>
            </div>
            <div class="phase-block">
              <div class="pb-label">Resultado</div>
              <p>A equipe opera com autonomia. O retainer mensal (a partir do 2º mês) é opcional, não dependência.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FJ SMART SCORE ══════════════════════════════════════ -->
  <section class="section score-section" id="score" aria-label="FJ Smart Score">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow eyebrow--gold">A métrica</div>
        <h2>FJ Smart Score — 5 dimensões, escala 0–5</h2>
        <p class="section-sub">
          Aplicado no início (Fase D) e no fim (Fase A) de todo projeto. A diferença entre os dois
          momentos é o <strong style="color:var(--strategic-gold)">Score Δ</strong> — a métrica que transforma
          "achamos que melhorou" em "estes são os números".
        </p>
      </div>

      <div class="score-dims-grid">
        <div class="score-dim-card">
          <div class="sdc-letter" style="color:var(--electric-cyan)">E</div>
          <h3>Estratégia</h3>
          <p>Existe clareza sobre prioridades de IA, donos de iniciativa e critérios de decisão? Ou cada área decide por conta própria?</p>
        </div>
        <div class="score-dim-card">
          <div class="sdc-letter" style="color:#4ADE80">P</div>
          <h3>Processos</h3>
          <p>Os fluxos de trabalho estão documentados e mapeados o suficiente para identificar onde a IA gera ganho real?</p>
        </div>
        <div class="score-dim-card">
          <div class="sdc-letter" style="color:#FB923C">D</div>
          <h3>Dados</h3>
          <p>A informação que alimentaria uma solução de IA existe, está acessível e tem qualidade suficiente?</p>
        </div>
        <div class="score-dim-card">
          <div class="sdc-letter" style="color:#A78BFA">T</div>
          <h3>Tecnologia</h3>
          <p>A stack atual suporta integração com IA, ou cada ferramenta nova vira mais um silo isolado?</p>
        </div>
        <div class="score-dim-card">
          <div class="sdc-letter" style="color:#34D399">P</div>
          <h3>Pessoas</h3>
          <p>A equipe tem letramento, confiança e abertura para operar com IA no dia a dia — ou há resistência e medo?</p>
        </div>
      </div>

      <div class="score-example">
        <div class="score-example-header">
          <span class="eyebrow">Exemplo ilustrativo</span>
          <span class="badge badge--green">Score Δ = +1.8</span>
        </div>
        <div class="score-example-rows">
          <div class="se-row">
            <span class="se-label">Estratégia</span>
            <div class="se-bar"><div class="se-fill" style="width:24%;background:var(--electric-cyan)"></div><div class="se-fill se-fill--end" style="width:76%;background:var(--electric-cyan)"></div></div>
            <span class="se-vals">1.2 → 3.8</span>
          </div>
          <div class="se-row">
            <span class="se-label">Processos</span>
            <div class="se-bar"><div class="se-fill" style="width:36%;background:#4ADE80"></div><div class="se-fill se-fill--end" style="width:64%;background:#4ADE80"></div></div>
            <span class="se-vals">1.8 → 3.2</span>
          </div>
          <div class="se-row">
            <span class="se-label">Dados</span>
            <div class="se-bar"><div class="se-fill" style="width:20%;background:#FB923C"></div><div class="se-fill se-fill--end" style="width:60%;background:#FB923C"></div></div>
            <span class="se-vals">1.0 → 3.0</span>
          </div>
          <div class="se-row">
            <span class="se-label">Tecnologia</span>
            <div class="se-bar"><div class="se-fill" style="width:30%;background:#A78BFA"></div><div class="se-fill se-fill--end" style="width:70%;background:#A78BFA"></div></div>
            <span class="se-vals">1.5 → 3.5</span>
          </div>
          <div class="se-row">
            <span class="se-label">Pessoas</span>
            <div class="se-bar"><div class="se-fill" style="width:28%;background:#34D399"></div><div class="se-fill se-fill--end" style="width:72%;background:#34D399"></div></div>
            <span class="se-vals">1.4 → 3.6</span>
          </div>
        </div>
        <div class="score-example-foot">Valores ilustrativos · cada projeto gera seu próprio Score Δ documentado no relatório de Autonomia.</div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ══════════════════════════════════════════════ -->
  <section class="section section--sm faq" aria-label="Perguntas frequentes">
    <div class="container container--narrow">
      <div class="section-header">
        <div class="eyebrow">Dúvidas comuns</div>
        <h2>Perguntas frequentes sobre o Método DELTA™</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Preciso contratar as 5 fases de uma vez?</summary>
          <p>Não. A entrada mais comum é pelo Diagnóstico (Fase D), que já entrega valor isolado. A partir dele, a continuidade para Estratégia, Lançamento, Transferência e Autonomia é recomendada — mas decidida fase a fase, com base no que o Diagnóstico revelar.</p>
        </details>
        <details class="faq-item">
          <summary>O que diferencia o DELTA de uma consultoria de tecnologia comum?</summary>
          <p>Duas coisas: (1) o ponto de partida é sempre um diagnóstico mensurável, nunca uma venda de ferramenta; e (2) o critério de sucesso é a autonomia do cliente — o projeto é considerado bem-sucedido quando a FJ Smart se torna opcional, não indispensável.</p>
        </details>
        <details class="faq-item">
          <summary>O FJ Smart Score serve para empresas de qualquer tamanho?</summary>
          <p>Sim. As 5 dimensões (Estratégia, Processos, Dados, Tecnologia, Pessoas) são aplicáveis tanto a uma operação de poucas pessoas quanto a empresas com múltiplas áreas — o que muda é a profundidade da entrevista e do roadmap gerado.</p>
        </details>
        <details class="faq-item">
          <summary>E se eu for um profissional individual, não uma empresa?</summary>
          <p>O Método DELTA também se aplica em versão B2C — veja a <a href="/servicos#b2c">Imersão IA Aplicada</a> e o <a href="/diagnostico">Diagnóstico Individual</a>, que seguem a mesma lógica de Diagnóstico → Estratégia → Autonomia adaptada à escala de uma carreira.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- ═══ CTA FINAL ════════════════════════════════════════ -->
  <section class="section cta-final" aria-label="Chamada para ação">
    <div class="container">
      <div class="cta-final-inner">
        <div class="eyebrow">Próximo passo</div>
        <h2>O Método começa com a letra <span class="md-accent">D</span>.</h2>
        <p>
          Não existe Estratégia sem Diagnóstico. Não existe Autonomia sem método.
          O primeiro passo está definido — e custa R$1.500 na oferta de lançamento.
        </p>
        <div class="cta-final-actions">
          <a href="/diagnostico" class="btn btn--primary" style="font-size:14px;padding:16px 36px;">
            Agendar Diagnóstico
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/servicos" class="btn btn--ghost">Ver portfólio completo</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ────────────────────────────────────────────── */
  .md-hero { padding-top: 5rem; overflow: hidden; position: relative; }
  .md-bg {
    position: absolute;
    right: -3%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(220px, 32vw, 460px);
    font-weight: 800;
    color: rgba(0,212,255,0.035);
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }
  .md-hero-inner { max-width: 720px; position: relative; z-index: 1; }
  .md-hero-inner .eyebrow { display: block; margin-bottom: 1rem; }
  .md-hero-inner h1 { margin-bottom: 1.25rem; }
  .md-accent { color: var(--electric-cyan); }
  .md-lead { font-size: 16px; margin-bottom: 1rem; }
  .md-hero-inner > p:not(.md-lead) { font-size: 15px; margin-bottom: 2rem; }
  .md-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* ─── WHY METHOD ──────────────────────────────────────── */
  .why-method { background: rgba(0,0,0,0.15); }
  .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .why-item { text-align: left; }
  .why-icon {
    width: 38px; height: 38px;
    border: 0.5px solid var(--border-cyan);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 0.85rem;
    background: rgba(0,212,255,0.04);
  }
  .why-item h3 { font-size: 14px; margin-bottom: 0.5rem; }
  .why-item p { font-size: 12.5px; line-height: 1.7; }

  /* ─── PHASES ──────────────────────────────────────────── */
  .section-header { text-align: center; margin-bottom: 3rem; }
  .section-header .eyebrow { display: block; margin-bottom: 0.75rem; }
  .section-header h2 { margin-bottom: 1rem; }
  .section-sub { font-size: 15px; max-width: 620px; margin: 0 auto; }

  .phase-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2rem;
    margin-bottom: 1rem;
  }
  .phase-row--last { margin-bottom: 0; }
  .phase-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .phase-letter {
    font-family: var(--font-display);
    font-size: 2.75rem;
