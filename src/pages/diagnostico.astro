---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Diagnóstico de Maturidade em IA"
  description="Saiba exatamente onde sua empresa está em IA — FJ Smart Score em 5 dimensões, relatório executivo e roadmap de 90 dias. Oferta de lançamento: R$1.500."
  ogImage="/og-diagnostico.png"
>

  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="diag-hero section" aria-label="Diagnóstico de Maturidade em IA">
    <div class="dh-delta-bg" aria-hidden="true">D</div>
    <div class="container">
      <div class="diag-hero-inner">
        <div class="diag-hero-content">
          <div class="eyebrow">B2B · Fase D do Método DELTA™</div>
          <h1>Diagnóstico de<br><span class="dh-accent">Maturidade em IA</span></h1>
          <p class="diag-lead">
            Você não precisa estar pronto — precisa saber onde está.
          </p>
          <p>
            Em 5–7 dias úteis você recebe o <strong>FJ Smart Score</strong> em 5 dimensões,
            um relatório executivo com as Top 3 oportunidades priorizadas por ROI,
            e um roadmap de 90 dias acionável.
          </p>

          <!-- PREÇO COM ÂNCORA -->
          <div class="diag-price-box">
            <div class="diag-price-label">Investimento · Oferta de lançamento</div>
            <div class="diag-price-row">
              <span class="price-anchor" style="font-size:1.1rem;">R$2.500</span>
              <span class="price-promo">R$1.500</span>
            </div>
            <div class="diag-price-note">Vagas limitadas · Valor fixo pelo projeto completo</div>
          </div>

          <div class="diag-ctas">
            <a href="https://wa.me/5554996419886?text=Olá%20Felipe!%20Quero%20agendar%20meu%20Diagnóstico%20de%20Maturidade%20em%20IA." target="_blank" rel="noopener" class="btn btn--gold" style="font-size:14px;padding:16px 32px;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.532 5.862L.057 23.743a.5.5 0 00.625.626l5.88-1.474A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.895 0-3.668-.52-5.183-1.427l-.371-.22-3.847.963.983-3.847-.228-.374A10 10 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
              Agendar pelo WhatsApp
            </a>
            <a href="mailto:felipe@fjsmart.com.br?subject=Diagnóstico de Maturidade em IA" class="btn btn--ghost">
              Enviar e-mail
            </a>
          </div>
        </div>

        <div class="diag-hero-visual">
          <!-- Score Card -->
          <div class="score-card">
            <div class="score-card-header">
              <span class="eyebrow">FJ Smart Score</span>
              <span class="badge badge--cyan">5 dimensões · 0–5</span>
            </div>
            <div class="score-dims">
              <div class="score-dim-row">
                <span class="score-dim-name">Estratégia</span>
                <div class="score-bar-wrap"><div class="score-bar-fill" style="width:0%;background:var(--electric-cyan)"></div></div>
                <span class="score-dim-val">?/5</span>
              </div>
              <div class="score-dim-row">
                <span class="score-dim-name">Processos</span>
                <div class="score-bar-wrap"><div class="score-bar-fill" style="width:0%;background:#4ADE80"></div></div>
                <span class="score-dim-val">?/5</span>
              </div>
              <div class="score-dim-row">
                <span class="score-dim-name">Dados</span>
                <div class="score-bar-wrap"><div class="score-bar-fill" style="width:0%;background:#FB923C"></div></div>
                <span class="score-dim-val">?/5</span>
              </div>
              <div class="score-dim-row">
                <span class="score-dim-name">Tecnologia</span>
                <div class="score-bar-wrap"><div class="score-bar-fill" style="width:0%;background:#A78BFA"></div></div>
                <span class="score-dim-val">?/5</span>
              </div>
              <div class="score-dim-row">
                <span class="score-dim-name">Pessoas</span>
                <div class="score-bar-wrap"><div class="score-bar-fill" style="width:0%;background:#34D399"></div></div>
                <span class="score-dim-val">?/5</span>
              </div>
            </div>
            <div class="score-card-footer">
              <span class="score-footer-text">Aplicado na entrada e na saída do projeto.<br>O Score Δ é a prova de transformação.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ENTREGÁVEIS ═══════════════════════════════════════ -->
  <section class="section section--sm deliverables" aria-label="O que você recebe">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">O que você recebe</div>
        <h2>4 entregáveis em 5–7 dias úteis</h2>
      </div>
      <div class="del-grid">
        <div class="del-card">
          <div class="del-num eyebrow--gold eyebrow">01</div>
          <h3>FJ Smart Score</h3>
          <p>Avaliação quantitativa 0–5 em 5 dimensões: Estratégia, Processos, Dados, Tecnologia e Pessoas. Seu baseline de entrada — e a prova de evolução na saída.</p>
        </div>
        <div class="del-card">
          <div class="del-num eyebrow--gold eyebrow">02</div>
          <h3>Relatório Executivo</h3>
          <p>8 a 12 páginas com diagnóstico completo, gargalos identificados e recomendações estratégicas por área. Pronto para apresentar à liderança.</p>
        </div>
        <div class="del-card">
          <div class="del-num eyebrow--gold eyebrow">03</div>
          <h3>Top 3 Oportunidades</h3>
          <p>As três iniciativas de IA com maior potencial de retorno no seu contexto, priorizadas por ROI, esforço de implementação e impacto no negócio.</p>
        </div>
        <div class="del-card">
          <div class="del-num eyebrow--gold eyebrow">04</div>
          <h3>Roadmap de 90 Dias</h3>
          <p>Plano de ação acionável com sprints mensais — objetivo, responsável, ferramentas e critério de sucesso por iniciativa. Começa na segunda-feira seguinte.</p>
        </div>
      </div>

      <div class="del-addon">
        <div class="del-addon-left">
          <span class="badge badge--gold">Add-on opcional</span>
          <div class="del-addon-name">Apresentação à diretoria / board</div>
          <div class="del-addon-desc">Sessão de 60 min com Q&A ao vivo para apresentar o diagnóstico à liderança</div>
        </div>
        <div class="del-addon-price">
          <span>+ R$500</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PROCESSO ══════════════════════════════════════════ -->
  <section class="section section--sm process" aria-label="Como funciona o processo">
    <div class="container container--narrow">
      <div class="section-header">
        <div class="eyebrow">Como funciona</div>
        <h2>3 momentos em 5–7 dias</h2>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <div class="ps-marker ps-marker--cyan">01</div>
          <div class="ps-body">
            <h3>Briefing & alinhamento</h3>
            <p>Reunião de 30 minutos para alinhar contexto, objetivos e escopo do diagnóstico. Sem questionário genérico — a conversa é estruturada pelo Método DELTA.</p>
            <div class="ps-meta">30 min · Online</div>
          </div>
        </div>
        <div class="process-step">
          <div class="ps-marker ps-marker--gold">02</div>
          <div class="ps-body">
            <h3>Entrevista estruturada</h3>
            <p>90 minutos com os decisores do negócio. Mapeamento de processos críticos, nível de maturidade por dimensão e identificação das principais oportunidades.</p>
            <div class="ps-meta">90 min · Online com os decisores</div>
          </div>
        </div>
        <div class="process-step">
          <div class="ps-marker ps-marker--green">03</div>
          <div class="ps-body">
            <h3>Análise, scoring e entrega</h3>
            <p>Aplicação do FJ Smart Score, elaboração do relatório executivo e construção do roadmap. Entrega em até 5 dias úteis após a entrevista.</p>
            <div class="ps-meta">3–5 dias úteis · Entrega digital</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PARA QUEM É ════════════════════════════════════════ -->
  <section class="section section--sm for-whom" aria-label="Para quem é este serviço">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Para quem é</div>
        <h2>3 perfis que mais se beneficiam</h2>
      </div>
      <div class="fw-grid">
        <div class="fw-card">
          <div class="fw-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <h3>Executivo / Gestor</h3>
          <p>Quer apresentar um plano de IA concreto para o board, com dados de maturidade e ROI projetado — não mais uma lista de ferramentas.</p>
          <div class="fw-gain">Ganho: clareza estratégica + argumento para a liderança</div>
        </div>
        <div class="fw-card">
          <div class="fw-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3>Empreendedor / Dono</h3>
          <p>Quer transformar IA em ativo da empresa — não em mais uma dependência. Precisa saber por onde começar sem desperdiçar recursos.</p>
          <div class="fw-gain">Ganho: prioridade certa + investimento justificável</div>
        </div>
        <div class="fw-card">
          <div class="fw-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0112 0v2"/></svg>
          </div>
          <h3>Profissional Individual</h3>
          <p>Quer uma avaliação honesta de como a IA pode transformar sua carreira ou negócio — com um plano para os próximos 90 dias.</p>
          <div class="fw-gain">Diagnóstico Individual B2C: R$497</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ OBJEÇÃO / CONFIANÇA ═══════════════════════════════ -->
  <section class="section section--sm objection" aria-label="Por que vale o investimento">
    <div class="container container--narrow">
      <div class="objection-box">
        <div class="eyebrow" style="display:block;margin-bottom:0.75rem;">A pergunta certa</div>
        <blockquote class="objection-quote">
          "A questão não é o custo do diagnóstico —<br>
          é quanto custa continuar sem clareza por mais 6 meses."
        </blockquote>
        <p class="objection-sub">
          Sem um baseline de maturidade, cada iniciativa de IA começa do zero.
          Sem priorização por ROI, os recursos vão para o que parece importante, não para o que <strong>é</strong> importante.
          O Diagnóstico é a porta de entrada de menor risco e maior retorno da FJ Smart.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA FINAL ══════════════════════════════════════════ -->
  <section class="section cta-diag" aria-label="Agendar diagnóstico">
    <div class="container">
      <div class="cta-diag-inner">
        <div class="cta-diag-text">
          <div class="eyebrow" style="display:block;margin-bottom:0.75rem;">Pronto para começar?</div>
          <h2>Diagnóstico de<br>Maturidade em IA</h2>
          <div class="cta-diag-price">
            <span class="price-anchor">R$2.500</span>
            <span class="price-promo">R$1.500</span>
          </div>
          <div class="cta-promo-badge">⏳ Oferta de lançamento · Vagas limitadas</div>
        </div>
        <div class="cta-diag-actions">
          <a href="https://wa.me/5554996419886?text=Olá%20Felipe!%20Quero%20agendar%20meu%20Diagnóstico%20de%20Maturidade%20em%20IA." target="_blank" rel="noopener" class="btn btn--gold" style="font-size:14px;padding:16px 32px;width:100%;justify-content:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.532 5.862L.057 23.743a.5.5 0 00.625.626l5.88-1.474A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.895 0-3.668-.52-5.183-1.427l-.371-.22-3.847.963.983-3.847-.228-.374A10 10 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            Agendar pelo WhatsApp
          </a>
          <a href="mailto:felipe@fjsmart.com.br?subject=Diagnóstico de Maturidade em IA" class="btn btn--ghost" style="width:100%;justify-content:center;">
            felipe@fjsmart.com.br
          </a>
          <div class="cta-diag-fine">Resposta em até 24h · Sem compromisso na primeira conversa</div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ─── HERO ──────────────────────────────────────────────── */
  .diag-hero { padding-top: 5rem; overflow: hidden; }
  .dh-delta-bg {
    position: absolute;
    left: -1%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(180px, 28vw, 380px);
    font-weight: 800;
    color: rgba(0,212,255,0.03);
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }
  .diag-hero-inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
    min-height: 55vh;
  }
  .diag-hero-content .eyebrow { display: block; margin-bottom: 1rem; }
  .dh-accent { color: var(--electric-cyan); }
  .diag-lead {
    font-size: 1.15rem;
    color: var(--strategic-gold);
    font-weight: 500;
    font-style: italic;
    margin: 1rem 0 0.75rem;
  }
  .diag-hero-content p { font-size: 15px; margin-bottom: 1rem; }

  .diag-price-box {
    background: rgba(220,175,60,0.06);
    border: 1px solid var(--border-gold);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    margin: 1.75rem 0;
    display: inline-block;
  }
  .diag-price-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(220,175,60,0.55);
    margin-bottom: 0.5rem;
  }
  .diag-price-row { display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 0.35rem; }
  .diag-price-note {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }
  .diag-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  /* Score card */
  .score-card {
    background: rgba(255,255,255,0.03);
    border: 0.5px solid var(--border-cyan);
    border-radius: 12px;
    padding: 1.5rem;
    position: sticky;
    top: 90px;
  }
  .score-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .score-dims { display: flex; flex-direction: column; gap: 0.85rem; }
  .score-dim-row {
    display: grid;
    grid-template-columns: 80px 1fr 30px;
    gap: 10px;
    align-items: center;
  }
  .score-dim-name { font-size: 12px; color: var(--text-muted); }
  .score-bar-wrap {
    height: 4px;
    background: rgba(255,255,255,0.06);
    border-radius: 2px;
    overflow: hidden;
  }
  .score-bar-fill {
    height: 100%;
    border-radius: 2px;
    transition: width 0.8s ease;
  }
  .score-dim-val {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    text-align: right;
  }
  .score-card-footer {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 0.5px solid var(--border);
  }
  .score-footer-text {
    font-size: 11px;
    color: var(--text-dim);
    line-height: 1.6;
    display: block;
  }

  /* ─── ENTREGÁVEIS ───────────────────────────────────────── */
  .deliverables { background: rgba(0,0,0,0.12); }
  .section-header { text-align: center; margin-bottom: 2.5rem; }
  .section-header .eyebrow { display: block; margin-bottom: 0.5rem; }
  .del-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .del-card {
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: 9px;
    padding: 1.25rem;
    transition: border-color 0.2s;
  }
  .del-card:hover { border-color: var(--border-gold); }
  .del-num { display: block; margin-bottom: 0.6rem; }
  .del-card h3 { font-size: 14px; margin-bottom: 0.5rem; }
  .del-card p { font-size: 12.5px; line-height: 1.65; }
  .del-addon {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(220,175,60,0.04);
    border: 0.5px solid var(--border-gold);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .del-addon-left { display: flex; flex-direction: column; gap: 4px; }
  .del-addon-name { font-size: 14px; font-weight: 500; color: var(--off-white); margin-top: 4px; }
  .del-addon-desc { font-size: 12px; color: var(--text-muted); }
  .del-addon-price {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--strategic-gold);
    white-space: nowrap;
  }

  /* ─── PROCESSO ──────────────────────────────────────────── */
  .process-steps { display: flex; flex-direction: column; gap: 1rem; }
  .process-step {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 1.25rem;
    align-items: start;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: 9px;
  }
  .ps-marker {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 800;
    line-height: 1;
    text-align: center;
    padding-top: 3px;
  }
  .ps-marker--cyan { color: var(--electric-cyan); }
  .ps-marker--gold { color: var(--strategic-gold); }
  .ps-marker--green { color: var(--matrix-green); }
  .ps-body h3 { font-size: 14px; margin-bottom: 0.4rem; }
  .ps-body p { font-size: 13px; line-height: 1.7; margin-bottom: 0.5rem; }
  .ps-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 0.1em;
  }

  /* ─── PARA QUEM É ───────────────────────────────────────── */
  .fw-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .fw-card {
    background: var(--bg-card);
    border: 0.5px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    transition: border-color 0.2s;
  }
  .fw-card:hover { border-color: var(--border-cyan); }
  .fw-icon {
    width: 42px; height: 42px;
    border: 0.5px solid var(--border-cyan);
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    color: var(--electric-cyan);
    background: rgba(0,212,255,0.04);
    margin-bottom: 1rem;
  }
  .fw-card h3 { font-size: 14px; margin-bottom: 0.5rem; }
  .fw-card p { font-size: 12.5px; line-height: 1.65; margin-bottom: 0.75rem; }
  .fw-gain {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--strategic-gold);
    letter-spacing: 0.08em;
    padding-top: 0.6rem;
    border-top: 0.5px solid var(--border);
  }

  /* ─── OBJEÇÃO ───────────────────────────────────────────── */
  .objection-box {
    background: rgba(0,212,255,0.04);
    border-left: 2px solid var(--electric-cyan);
    border-radius: 0 10px 10px 0;
    padding: 2rem 2.5rem;
  }
  .objection-quote {
