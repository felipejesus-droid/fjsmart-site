---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "FJ Smart — Inteligência Pessoal. Transformação digital com IA para empresas e profissionais. Método DELTA: do diagnóstico à autonomia.",
  ogImage = "/og-default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Redes sociais — substitua "#" pelos links reais quando disponíveis
const SOCIAL_LINKS = {
  instagram: "https://www.instagram.com/fj.smarttd/",
  tiktok: "https://www.tiktok.com/@fjsmart.td",
  x: "https://x.com/FelipeJesu57748",
  youtube: "https://www.youtube.com/@fjsmart",
  spotify: "https://open.spotify.com/user/31qcwwvykvlllamvso7p4rkxxs34",
  linkedin: "https://www.linkedin.com/in/fj-smart-intelig%C3%AAncia-pessoal-888a2140a/",
};
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · FJ Smart</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} · FJ Smart`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} · FJ Smart`} />
  <meta name="twitter:description" content={description} />

  <!-- Favicon placeholder -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>

<body>
  <!-- NAV -->
  <header class="site-header" id="top">
    <div class="container">
      <nav class="nav">
        <a href="/" class="nav-logo" aria-label="FJ Smart — Início">
          <div class="nav-logo-mark">FJ</div>
          <div class="nav-logo-text">
            <span class="nav-logo-brand">FJ SMART</span>
            <span class="nav-logo-tagline">Inteligência Pessoal</span>
          </div>
        </a>

        <button class="nav-toggle" id="navToggle" aria-label="Menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

        <ul class="nav-links" id="navLinks">
        <li><a href="/guia-delta" class="nav-link nav-link--gift">🎁 Guia DELTA</a></li>
          <li><a href="/metodo-delta" class="nav-link">Método DELTA</a></li>
          <li><a href="/servicos" class="nav-link">Serviços</a></li>
          <li><a href="/sobre" class="nav-link">Sobre</a></li>
          <li><a href="/diagnostico" class="nav-cta btn btn--primary">Agendar Diagnóstico</a></li>
        </ul>
      </nav>
    </div>
    <div class="accent-bar"></div>
  </header>

  <!-- MAIN -->
  <main id="main">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="accent-bar"></div>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="nav-logo-mark" style="width:44px;height:44px;font-size:15px;">FJ</div>
          <div style="margin-top:0.75rem;">
            <div class="footer-brand-name">FJ SMART</div>
            <div class="footer-tagline">Inteligência Pessoal</div>
          </div>
          <p class="footer-mission">
            Transformando potencial humano e organizacional em inteligência estratégica.
          </p>
        </div>

        <div class="footer-col">
          <div class="footer-col-title">Serviços</div>
          <ul class="footer-links">
            <li><a href="/diagnostico">Diagnóstico de Maturidade em IA</a></li>
            <li><a href="/servicos#b2b">Transformação DELTA Completa</a></li>
            <li><a href="/servicos#b2b">Capacitação em IA para Equipes</a></li>
            <li><a href="/servicos#b2c">Mentoria Individual</a></li>
